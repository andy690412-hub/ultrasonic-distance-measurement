import serial
import time

# 아까 확인한 장치명으로 수정하세요!
ser = serial.Serial('/dev/ttyACM0', 9600)

try:
    while True:
        if ser.in_waiting > 0:
            data = ser.readline().decode('utf-8').strip()
            print(f"[{time.ctime()}] 센서값: {data}")
            # 여기서 파일을 열어 저장하면 됩니다.
except KeyboardInterrupt:
    ser.close()
